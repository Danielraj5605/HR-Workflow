# HR Workflow Designer — Environment Variables
# Copy this file to .env.local and fill in your values.
# You only need ONE of the AI provider keys (or enter it directly in the AI panel at runtime).

# ── Anthropic Claude ─────────────────────────────────────────────────────
# Get your key: https://console.anthropic.com/
VITE_ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ── Google Gemini ─────────────────────────────────────────────────────────
# Get your key: https://aistudio.google.com/app/apikey
VITE_GEMINI_API_KEY=your_gemini_api_key_here

# ── MiniMax ───────────────────────────────────────────────────────────────
# Get your key: https://platform.minimaxi.com/
VITE_MINIMAX_API_KEY=your_minimax_api_key_here
